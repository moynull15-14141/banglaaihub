# Without this, `npm install` under NODE_ENV=production (which Render sets,
# correctly, as a runtime env var) silently skips devDependencies — and this
# is a TypeScript project where `typescript` itself plus every `@types/*`
# package live in devDependencies but are required to build (tsc), not just
# to run. That mismatch is what broke the Render build: `Cannot find a
# declaration file for module 'express'` etc. `include=dev` forces devDeps
# to install regardless of NODE_ENV; they're compiled away by `tsc` and
# unused at runtime (`npm start` only runs dist/), so leaving them installed
# afterward is harmless.
include=dev
