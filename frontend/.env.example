# .env.example — copy to .env.local and fill in real values
# NEVER commit .env.local — only commit .env.example
# Anything prefixed NEXT_PUBLIC_ is bundled into client JS and is PUBLIC — never put secrets here.

NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GITHUB_URL=

# NEXT_PUBLIC_MEILISEARCH_URL / NEXT_PUBLIC_MEILISEARCH_KEY removed —
# confirmed unused anywhere in frontend/src (search is always proxied
# through the backend's /search endpoint, the frontend never talks to
# MeiliSearch directly). Re-add only if that architecture changes.
